{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug demo1 (NestJS)",
      "type": "node",
      "request": "launch",
      "runtimeArgs": ["--nolazy", "-r", "ts-node/register"],
      "args": ["${workspaceFolder}/ts/demo1/src/main.ts"],
      "sourceMaps": true,
      "envFile": "${workspaceFolder}/ts/demo1/.env",
      "cwd": "${workspaceFolder}/ts/demo1",
      "console": "integratedTerminal",
      "env": {
        "NODE_ENV": "development"
      }
    }
  ]
}
