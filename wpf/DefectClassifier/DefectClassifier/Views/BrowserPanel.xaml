<UserControl x:Class="DefectClassifier.Views.BrowserPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#252526">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D2D2D" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1" Padding="10,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="晶圓ID：" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="12"/>
                <TextBox Width="100" Margin="4,0,0,0" Padding="4,2"
                         Text="{Binding FilterWaferId, UpdateSourceTrigger=PropertyChanged}"
                         Background="#3C3C3C" Foreground="#CCCCCC" BorderBrush="#555555"/>
                <Button Content="篩選" Command="{Binding ApplyFilterCommand}" Style="{StaticResource DarkButton}" Margin="8,0,0,0"/>
                <Button Content="清除" Command="{Binding ClearFilterCommand}" Style="{StaticResource DarkButton}" Margin="4,0,0,0"/>
                <Separator Width="1" Background="#3C3C3C" Margin="16,0"/>
                <TextBlock Text="拖放類型標籤至列表項目可快速分類" VerticalAlignment="Center" Foreground="#666666" FontSize="11"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <ListView Grid.Column="0"
                      x:Name="DefectListView"
                      ItemsSource="{Binding Defects}"
                      SelectedItem="{Binding SelectedDefect}"
                      Background="#1E1E1E"
                      Foreground="#CCCCCC"
                      BorderBrush="#3C3C3C"
                      AllowDrop="True"
                      Drop="ListView_Drop"
                      DragOver="ListView_DragOver">
                <ListView.Resources>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="4,3"/>
                        <Setter Property="Foreground" Value="#CCCCCC"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#094771"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2D2E"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListView.Resources>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="ID" Width="50" DisplayMemberBinding="{Binding Id}"/>
                        <GridViewColumn Header="類型" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="10" Height="10" CornerRadius="2" Margin="0,0,5,0"
                                                Background="{Binding Type, Converter={StaticResource DefectTypeToColorConverter}}"/>
                                        <TextBlock Text="{Binding Type, Converter={StaticResource DefectTypeToStringConverter}}"
                                                   Foreground="#CCCCCC" FontSize="11"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="晶圓ID" Width="70" DisplayMemberBinding="{Binding WaferId}"/>
                        <GridViewColumn Header="位置 (X,Y)" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Foreground="#CCCCCC" FontSize="11">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="({0:F1}, {1:F1})">
                                                <Binding Path="X"/>
                                                <Binding Path="Y"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="尺寸 (WxH)" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Foreground="#CCCCCC" FontSize="11">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0:F1}x{1:F1}">
                                                <Binding Path="Width"/>
                                                <Binding Path="Height"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="嚴重度" Width="60" DisplayMemberBinding="{Binding Severity}"/>
                        <GridViewColumn Header="時間" Width="130">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Timestamp, StringFormat=MM-dd HH:mm}"
                                               Foreground="#CCCCCC" FontSize="11"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#3C3C3C"/>

            <ScrollViewer Grid.Column="2" Background="#2D2D2D" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10">
                    <TextBlock Text="分類標記" Foreground="#FFFFFF" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
                    <TextBlock Text="點擊套用至選取缺陷，或拖放至列表" Foreground="#666666" FontSize="10" Margin="0,0,0,10" TextWrapping="Wrap"/>

                    <ItemsControl ItemsSource="{Binding ClassificationTypes}" x:Name="TypeButtons">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,3" CornerRadius="4" Cursor="Hand"
                                        Background="{Binding Converter={StaticResource DefectTypeToColorConverter}}"
                                        Opacity="0.85"
                                        PreviewMouseLeftButtonDown="TypeTag_MouseLeftButtonDown"
                                        PreviewMouseMove="TypeTag_MouseMove"
                                        MouseLeftButtonUp="TypeTag_Click">
                                    <TextBlock Text="{Binding Converter={StaticResource DefectTypeToStringConverter}}"
                                               Foreground="White" FontWeight="Bold" FontSize="12"
                                               Padding="10,6" HorizontalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Separator Background="#3C3C3C" Margin="0,14"/>

                    <TextBlock Text="缺陷詳細資訊" Foreground="#FFFFFF" FontWeight="Bold" FontSize="13" Margin="0,0,0,8"
                               Visibility="{Binding SelectedDefect, Converter={StaticResource NullToVisibilityConverter}}"/>

                    <StackPanel Visibility="{Binding SelectedDefect, Converter={StaticResource NullToVisibilityConverter}}">
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ID：" Style="{StaticResource LabelText}"/>
                            <TextBlock Grid.Column="1" Text="{Binding SelectedDefect.Id}" Style="{StaticResource ValueText}"/>
                        </Grid>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="類型：" Style="{StaticResource LabelText}"/>
                            <TextBlock Grid.Column="1" Text="{Binding SelectedDefect.Type, Converter={StaticResource DefectTypeToStringConverter}}" Style="{StaticResource ValueText}"/>
                        </Grid>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="晶圓ID：" Style="{StaticResource LabelText}"/>
                            <TextBlock Grid.Column="1" Text="{Binding SelectedDefect.WaferId}" Style="{StaticResource ValueText}"/>
                        </Grid>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="位置：" Style="{StaticResource LabelText}"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource ValueText}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="({0:F2}, {1:F2})">
                                        <Binding Path="SelectedDefect.X"/>
                                        <Binding Path="SelectedDefect.Y"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="尺寸：" Style="{StaticResource LabelText}"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource ValueText}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:F2} x {1:F2}">
                                        <Binding Path="SelectedDefect.Width"/>
                                        <Binding Path="SelectedDefect.Height"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="面積：" Style="{StaticResource LabelText}"/>
                            <TextBlock Grid.Column="1" Text="{Binding SelectedDefect.Area, StringFormat={}{0:F2}}" Style="{StaticResource ValueText}"/>
                        </Grid>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="嚴重度：" Style="{StaticResource LabelText}"/>
                            <TextBlock Grid.Column="1" Text="{Binding SelectedDefect.Severity}" Style="{StaticResource ValueText}"/>
                        </Grid>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="時間：" Style="{StaticResource LabelText}"/>
                            <TextBlock Grid.Column="1" Text="{Binding SelectedDefect.Timestamp, StringFormat=yyyy-MM-dd HH:mm}" Style="{StaticResource ValueText}"/>
                        </Grid>

                        <Button Content="刪除此缺陷" Command="{Binding DeleteDefectCommand}"
                                Style="{StaticResource DarkButton}" Margin="0,12,0,0"
                                Background="#7B2C2C" BorderBrush="#A03333"/>
                    </StackPanel>

                    <TextBlock Visibility="{Binding SelectedDefect, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"
                               Text="← 請從左側列表選取缺陷" Foreground="#555555" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,20"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
