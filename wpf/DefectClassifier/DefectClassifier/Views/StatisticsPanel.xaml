<UserControl x:Class="DefectClassifier.Views.StatisticsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#252526">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock Text="統計儀表板" Foreground="#FFFFFF" FontWeight="Bold" FontSize="18" VerticalAlignment="Center"/>
                <Button Content="重新整理" Command="{Binding RefreshStatsCommand}"
                        Style="{StaticResource DarkButton}" Margin="16,0,0,0"/>
            </StackPanel>

            <WrapPanel Margin="0,0,0,16">
                <Border Background="#007ACC" CornerRadius="6" Padding="20,14" Margin="0,0,12,12" MinWidth="160">
                    <StackPanel>
                        <TextBlock Text="缺陷總數" Foreground="#B8D4EA" FontSize="11"/>
                        <TextBlock Text="{Binding TotalDefects}" Foreground="White" FontSize="36" FontWeight="Bold"/>
                        <TextBlock Text="筆記錄" Foreground="#B8D4EA" FontSize="11"/>
                    </StackPanel>
                </Border>
                <Border Background="#27AE60" CornerRadius="6" Padding="20,14" Margin="0,0,12,12" MinWidth="160">
                    <StackPanel>
                        <TextBlock Text="預估良率" Foreground="#A9DFC0" FontSize="11"/>
                        <TextBlock Text="{Binding Yield, StringFormat={}{0:F1}%}" Foreground="White" FontSize="36" FontWeight="Bold"/>
                        <TextBlock Text="(嚴重度≥3 缺陷影響)" Foreground="#A9DFC0" FontSize="10"/>
                    </StackPanel>
                </Border>
                <Border Background="#8E44AD" CornerRadius="6" Padding="20,14" Margin="0,0,12,12" MinWidth="160">
                    <StackPanel>
                        <TextBlock Text="晶圓數量" Foreground="#D7B8EA" FontSize="11"/>
                        <TextBlock Text="{Binding WaferCount}" Foreground="White" FontSize="36" FontWeight="Bold"/>
                        <TextBlock Text="片" Foreground="#D7B8EA" FontSize="11"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#2D2D2D" CornerRadius="6" Padding="14">
                    <StackPanel>
                        <TextBlock Text="缺陷類型分布" Foreground="#FFFFFF" FontWeight="Bold" FontSize="13" Margin="0,0,0,12"/>
                        <ItemsControl ItemsSource="{Binding TypeChartData}" Height="200">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0" VerticalAlignment="Bottom"
                                                Height="{Binding BarHeight}"
                                                Background="{Binding BarBrush}"
                                                CornerRadius="3,3,0,0"/>
                                        <TextBlock Grid.Row="1" Text="{Binding Value}"
                                                   HorizontalAlignment="Center" Foreground="#CCCCCC" FontSize="11" FontWeight="Bold"/>
                                        <TextBlock Grid.Row="2" Text="{Binding Label}"
                                                   HorizontalAlignment="Center" Foreground="#AAAAAA" FontSize="9"
                                                   TextWrapping="Wrap" TextAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#2D2D2D" CornerRadius="6" Padding="14">
                    <StackPanel>
                        <TextBlock Text="每日缺陷趨勢" Foreground="#FFFFFF" FontWeight="Bold" FontSize="13" Margin="0,0,0,12"/>
                        <ItemsControl ItemsSource="{Binding TrendChartData}" Height="200">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="3,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0" VerticalAlignment="Bottom"
                                                Height="{Binding BarHeight}"
                                                Background="{Binding BarBrush}"
                                                CornerRadius="2,2,0,0"/>
                                        <TextBlock Grid.Row="1" Text="{Binding Value}"
                                                   HorizontalAlignment="Center" Foreground="#CCCCCC" FontSize="10"/>
                                        <TextBlock Grid.Row="2" Text="{Binding Label}"
                                                   HorizontalAlignment="Center" Foreground="#AAAAAA" FontSize="9"
                                                   TextWrapping="Wrap" TextAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="#2D2D2D" CornerRadius="6" Padding="14">
                <StackPanel>
                    <TextBlock Text="各晶圓缺陷數" Foreground="#FFFFFF" FontWeight="Bold" FontSize="13" Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding WaferChartData}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Label}"
                                               Foreground="#CCCCCC" FontSize="12" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" VerticalAlignment="Center"
                                            Height="16" CornerRadius="3"
                                            HorizontalAlignment="Left"
                                            MinWidth="4">
                                        <Border.Width>
                                            <Binding Path="BarHeight"/>
                                        </Border.Width>
                                        <Border.Background>
                                            <Binding Path="BarBrush"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="{Binding Value}"
                                               Foreground="#CCCCCC" FontSize="12" VerticalAlignment="Center"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
