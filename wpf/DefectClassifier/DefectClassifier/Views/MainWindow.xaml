<Window x:Class="DefectClassifier.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:DefectClassifier.Views"
        mc:Ignorable="d"
        Title="DefectClassifier - 晶圓缺陷分類管理系統"
        Height="800" Width="1280"
        MinHeight="600" MinWidth="900"
        Background="#1E1E1E">

    <DockPanel>
        <StatusBar DockPanel.Dock="Bottom" Background="#007ACC" Height="24">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>

        <TabControl SelectedIndex="{Binding SelectedTabIndex}"
                    Background="#252526"
                    BorderBrush="#3C3C3C">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#2D2D2D"/>
                    <Setter Property="Foreground" Value="#CCCCCC"/>
                    <Setter Property="Padding" Value="16,6"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#007ACC"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <TabItem Header="缺陷瀏覽">
                <views:BrowserPanel DataContext="{Binding BrowserVM}"/>
            </TabItem>

            <TabItem Header="統計儀表板">
                <views:StatisticsPanel DataContext="{Binding StatisticsVM}"/>
            </TabItem>

            <TabItem Header="自動分類">
                <views:ClassificationPanel DataContext="{Binding ClassificationVM}"/>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
