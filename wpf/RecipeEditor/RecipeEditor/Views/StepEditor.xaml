<UserControl x:Class="RecipeEditor.Views.StepEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:RecipeEditor.ViewModels"
             xmlns:models="clr-namespace:RecipeEditor.Models">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListBox x:Name="StepList"
                 Grid.Row="0"
                 ItemsSource="{Binding Steps}"
                 SelectedItem="{Binding SelectedStep}"
                 AllowDrop="True"
                 Background="#FAFAFA"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 PreviewMouseLeftButtonDown="StepList_PreviewMouseLeftButtonDown"
                 PreviewMouseMove="StepList_PreviewMouseMove"
                 Drop="StepList_Drop"
                 DragOver="StepList_DragOver">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="4,2"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="Bd"
                                        Background="White"
                                        BorderBrush="#E0E0E0"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="0">
                                    <ContentPresenter/>
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="SelectionStates">
                                            <VisualState x:Name="Selected">
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="Bd"
                                                                    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                    To="#E3F2FD" Duration="0"/>
                                                    <ColorAnimation Storyboard.TargetName="Bd"
                                                                    Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                                    To="#1976D2" Duration="0"/>
                                                </Storyboard>
                                            </VisualState>
                                            <VisualState x:Name="Unselected"/>
                                            <VisualState x:Name="SelectedUnfocused">
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="Bd"
                                                                    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                    To="#E3F2FD" Duration="0"/>
                                                </Storyboard>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:StepViewModel}">
                    <Grid Height="52">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" Fill="{Binding StepTypeColor}" RadiusX="3" RadiusY="3"/>
                        <StackPanel Grid.Column="1" Margin="8,4" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" Foreground="#212121"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="{Binding StepType}" FontSize="11" Foreground="#757575"/>
                                <TextBlock Text=" · " FontSize="11" Foreground="#BDBDBD"/>
                                <TextBlock Text="{Binding DurationDisplay}" FontSize="11" Foreground="#757575"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="1" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="4">
            <WrapPanel>
                <Button Content="+ Deposition" Margin="2" Padding="6,3"
                        Command="{Binding AddStepCommand}"
                        CommandParameter="{x:Static models:StepType.Deposition}"
                        Background="#E3F2FD" BorderBrush="#90CAF9" FontSize="11"/>
                <Button Content="+ Etch" Margin="2" Padding="6,3"
                        Command="{Binding AddStepCommand}"
                        CommandParameter="{x:Static models:StepType.Etch}"
                        Background="#FFEBEE" BorderBrush="#EF9A9A" FontSize="11"/>
                <Button Content="+ Clean" Margin="2" Padding="6,3"
                        Command="{Binding AddStepCommand}"
                        CommandParameter="{x:Static models:StepType.Clean}"
                        Background="#E8F5E9" BorderBrush="#A5D6A7" FontSize="11"/>
                <Button Content="+ Anneal" Margin="2" Padding="6,3"
                        Command="{Binding AddStepCommand}"
                        CommandParameter="{x:Static models:StepType.Anneal}"
                        Background="#FFF3E0" BorderBrush="#FFCC80" FontSize="11"/>
                <Button Content="+ Transfer" Margin="2" Padding="6,3"
                        Command="{Binding AddStepCommand}"
                        CommandParameter="{x:Static models:StepType.Transfer}"
                        Background="#F3E5F5" BorderBrush="#CE93D8" FontSize="11"/>
                <Button Content="+ Wait" Margin="2" Padding="6,3"
                        Command="{Binding AddStepCommand}"
                        CommandParameter="{x:Static models:StepType.Wait}"
                        Background="#ECEFF1" BorderBrush="#B0BEC5" FontSize="11"/>
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,0"/>
                <Button Content="▲" Margin="2" Padding="6,3" ToolTip="Move Up"
                        Command="{Binding MoveStepUpCommand}" FontSize="11"/>
                <Button Content="▼" Margin="2" Padding="6,3" ToolTip="Move Down"
                        Command="{Binding MoveStepDownCommand}" FontSize="11"/>
                <Button Content="⧉" Margin="2" Padding="6,3" ToolTip="Duplicate"
                        Command="{Binding DuplicateStepCommand}" FontSize="11"/>
                <Button Content="✕" Margin="2" Padding="6,3" ToolTip="Remove"
                        Command="{Binding RemoveStepCommand}" FontSize="11"
                        Background="#FFEBEE" BorderBrush="#EF9A9A"/>
            </WrapPanel>
        </Border>
    </Grid>
</UserControl>
