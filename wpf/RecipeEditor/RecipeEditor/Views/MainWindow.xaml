<Window x:Class="RecipeEditor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:RecipeEditor.Views"
        xmlns:converters="clr-namespace:RecipeEditor.Converters"
        Title="Recipe Editor — Semiconductor Process Tool"
        Width="1100" Height="720"
        MinWidth="900" MinHeight="560"
        Background="#F5F5F5">
    <Window.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVis"/>
        <converters:NotNullToVisibilityConverter x:Key="NotNullToVis"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="ToolbarBtn" TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1565C0" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚙ Recipe Editor" Foreground="White"
                           FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Text=" — Semiconductor Process Tool" Foreground="#90CAF9"
                           FontSize="14" VerticalAlignment="Center" Margin="4,0,0,0"/>
            </StackPanel>
        </Border>

        <ToolBar Grid.Row="1" Background="#E3F2FD" BorderBrush="#BBDEFB" BorderThickness="0,0,0,1">
            <Button Style="{StaticResource ToolbarBtn}" Content="⬜ New"
                    Command="{Binding NewRecipeCommand}" ToolTip="New Recipe (Ctrl+N)"/>
            <Button Style="{StaticResource ToolbarBtn}" Content="📂 Open"
                    Command="{Binding OpenRecipeCommand}" ToolTip="Open Recipe (Ctrl+O)"/>
            <Button Style="{StaticResource ToolbarBtn}" Content="💾 Save"
                    Command="{Binding SaveRecipeCommand}" ToolTip="Save Recipe (Ctrl+S)"/>
            <Separator/>
            <Button Style="{StaticResource ToolbarBtn}" Content="↩ Undo"
                    Command="{Binding UndoCommand}" ToolTip="Undo (Ctrl+Z)"/>
            <Button Style="{StaticResource ToolbarBtn}" Content="↪ Redo"
                    Command="{Binding RedoCommand}" ToolTip="Redo (Ctrl+Y)"/>
            <Separator/>
            <Button Style="{StaticResource ToolbarBtn}" Content="✔ Validate"
                    Command="{Binding ValidateCommand}" ToolTip="Validate Recipe"/>
        </ToolBar>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="290"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#E3F2FD" Padding="12,8">
                        <TextBlock Text="Recipe Info" FontSize="13" FontWeight="SemiBold" Foreground="#1565C0"/>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="12" DataContext="{Binding Recipe}">
                            <TextBlock Text="Name" FontSize="11" Foreground="#757575" Margin="0,8,0,2"/>
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                     BorderBrush="#BDBDBD" Padding="6,4" FontSize="13"/>

                            <TextBlock Text="Version" FontSize="11" Foreground="#757575" Margin="0,8,0,2"/>
                            <TextBox Text="{Binding Version, UpdateSourceTrigger=PropertyChanged}"
                                     BorderBrush="#BDBDBD" Padding="6,4"/>

                            <TextBlock Text="Author" FontSize="11" Foreground="#757575" Margin="0,8,0,2"/>
                            <TextBox Text="{Binding Author, UpdateSourceTrigger=PropertyChanged}"
                                     BorderBrush="#BDBDBD" Padding="6,4"/>

                            <TextBlock Text="Description" FontSize="11" Foreground="#757575" Margin="0,8,0,2"/>
                            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                     BorderBrush="#BDBDBD" Padding="6,4"
                                     AcceptsReturn="True" Height="70" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"/>

                            <Border Margin="0,16,0,0" Background="#E3F2FD" CornerRadius="4" Padding="10,8">
                                <StackPanel>
                                    <TextBlock Text="Steps" FontSize="11" Foreground="#757575"/>
                                    <TextBlock FontSize="20" FontWeight="Bold" Foreground="#1565C0">
                                        <TextBlock.Text>
                                            <Binding Path="Steps.Count"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#E0E0E0"/>

            <Border Grid.Column="2" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#E3F2FD" Padding="12,8">
                        <TextBlock Text="Process Steps" FontSize="13" FontWeight="SemiBold" Foreground="#1565C0"/>
                    </Border>
                    <local:StepEditor Grid.Row="1" DataContext="{Binding Recipe}"/>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="#E0E0E0"/>

            <Border Grid.Column="4" Background="#FAFAFA">
                <Grid>
                    <TextBlock Text="Select a step to edit its properties"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#9E9E9E" FontSize="14"
                               Visibility="{Binding Recipe.SelectedStep, Converter={StaticResource NullToVis}}"/>
                    <local:ParameterEditor
                        DataContext="{Binding Recipe.SelectedStep}"
                        Visibility="{Binding Recipe.SelectedStep, Converter={StaticResource NotNullToVis}}"/>
                </Grid>
            </Border>
        </Grid>

        <local:ValidationPanel Grid.Row="3" DataContext="{Binding}"/>

        <Border Grid.Row="4" Background="#E3F2FD" BorderBrush="#BBDEFB" BorderThickness="0,1,0,0" Padding="12,4">
            <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="#1565C0"/>
        </Border>
    </Grid>
</Window>
