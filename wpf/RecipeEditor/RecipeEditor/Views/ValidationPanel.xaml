<UserControl x:Class="RecipeEditor.Views.ValidationPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:RecipeEditor.ViewModels">
    <Expander Header="Validation Results" IsExpanded="False" Background="#FAFAFA">
        <Border MaxHeight="160" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding ValidationResults}" Margin="4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ValidationResultViewModel}">
                            <StackPanel Orientation="Horizontal" Margin="4,2">
                                <TextBlock Text="{Binding Icon}"
                                           Foreground="{Binding Color}"
                                           FontSize="13" Width="20" TextAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Message}"
                                           Foreground="{Binding Color}"
                                           FontSize="12" VerticalAlignment="Center" Margin="4,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Expander>
</UserControl>
