<UserControl x:Class="RealtimeDataMonitor.Views.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#1A1A24" Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="SETTINGS" FontWeight="Bold" Foreground="#2D7DD2"
                   FontSize="14" Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock Text="Time Window (seconds)" Foreground="#AAAACC" FontSize="12" Margin="0,0,0,4"/>
            <StackPanel Orientation="Horizontal">
                <Slider Value="{Binding TimeWindowSeconds}" Minimum="5" Maximum="120"
                        Width="160" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding TimeWindowSeconds, StringFormat={}{0:F0}s}"
                           Foreground="White" VerticalAlignment="Center" FontSize="13"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,16">
            <TextBlock Text="Samples / Second" Foreground="#AAAACC" FontSize="12" Margin="0,0,0,4"/>
            <StackPanel Orientation="Horizontal">
                <Slider Value="{Binding SamplesPerSecond}" Minimum="10" Maximum="500"
                        Width="160" VerticalAlignment="Center" Margin="0,0,8,0"
                        IsSnapToTickEnabled="True" TickFrequency="10"/>
                <TextBlock Text="{Binding SamplesPerSecond, StringFormat={}{0} Hz}"
                           Foreground="White" VerticalAlignment="Center" FontSize="13"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="3">
            <TextBlock Text="Channel Thresholds" Foreground="#AAAACC" FontSize="12" Margin="0,0,0,8"/>
            <ItemsControl ItemsSource="{Binding ChannelSettings.Channels}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#22222E" CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                           Text="{Binding Name}" Foreground="White"
                                           FontWeight="Bold" Margin="0,0,0,6"/>

                                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="High: " Foreground="#AAAACC" FontSize="11"/>
                                    <TextBox Text="{Binding UpperThreshold, UpdateSourceTrigger=PropertyChanged}"
                                             Width="50" FontSize="11" Background="#33334A"
                                             Foreground="White" BorderThickness="0" Padding="2"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="Low:  " Foreground="#AAAACC" FontSize="11"/>
                                    <TextBox Text="{Binding LowerThreshold, UpdateSourceTrigger=PropertyChanged}"
                                             Width="50" FontSize="11" Background="#33334A"
                                             Foreground="White" BorderThickness="0" Padding="2"/>
                                </StackPanel>

                                <CheckBox Grid.Row="1" Grid.Column="1" Grid.RowSpan="2"
                                          IsChecked="{Binding IsEnabled}"
                                          Content="On" Foreground="White"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</UserControl>
