<Window x:Class="RealtimeDataMonitor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:RealtimeDataMonitor.Views"
        xmlns:converters="clr-namespace:RealtimeDataMonitor.Converters"
        Title="Realtime Data Monitor" Height="720" Width="1280"
        Background="#12121A" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <converters:BoolToRunningTextConverter x:Key="BoolToRunningTextConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#22222E" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Realtime Data Monitor"
                           Foreground="White" FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Width="90" Margin="0,0,6,0"
                            Command="{Binding StartCommand}"
                            IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolConverter}}"
                            Style="{StaticResource SuccessButton}"
                            Content="Start"/>
                    <Button Width="90" Margin="0,0,6,0"
                            Command="{Binding StopCommand}"
                            IsEnabled="{Binding IsRunning}"
                            Style="{StaticResource DangerButton}"
                            Content="Stop"/>
                    <Button Width="100" Margin="0,0,6,0"
                            Command="{Binding ClearChartCommand}"
                            Style="{StaticResource ModernButton}"
                            Content="Clear Chart"/>
                    <Button Width="120" Margin="0,0,6,0"
                            Command="{Binding ExportDataCommand}"
                            IsEnabled="{Binding IsExporting, Converter={StaticResource InverseBoolConverter}}"
                            Style="{StaticResource ModernButton}"
                            Content="Export Data"/>
                    <Button Width="130"
                            Command="{Binding ExportAlarmsCommand}"
                            IsEnabled="{Binding IsExporting, Converter={StaticResource InverseBoolConverter}}"
                            Style="{StaticResource ModernButton}"
                            Content="Export Alarms"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="370"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <views:SettingsPanel/>
            </ScrollViewer>

            <views:ChartPanel Grid.Column="1"/>

            <views:AlarmPanel Grid.Column="2"/>
        </Grid>

        <Border Grid.Row="2" Background="#22222E" Padding="12,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                           Foreground="#AAAACC" FontSize="12" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Active Alarms: " Foreground="#AAAACC" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Alarm.ActiveAlarmCount}"
                               Foreground="#E63946" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
