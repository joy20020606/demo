<Window x:Class="ImageInspector.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ImageInspector.Views"
        xmlns:vm="clr-namespace:ImageInspector.ViewModels"
        xmlns:converters="clr-namespace:ImageInspector.Converters"
        xmlns:models="clr-namespace:ImageInspector.Models"
        mc:Ignorable="d"
        Title="ImageInspector - E-beam 影像檢視器"
        Height="800" Width="1280"
        MinHeight="600" MinWidth="900"
        Background="#252526">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style TargetType="Label" x:Key="SectionLabel">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="0,4,0,2"/>
        </Style>

        <Style TargetType="Slider" x:Key="ControlSlider">
            <Setter Property="Foreground" Value="#0E90D2"/>
        </Style>

        <Style TargetType="Button" x:Key="ToolButton">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#505050"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="RadioButton" x:Key="ShapeButton">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Padding" Value="4,2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#094771"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="#2D2D2D" Foreground="#CCCCCC">
            <MenuItem Header="File" Foreground="#CCCCCC">
                <MenuItem Header="載入影像" Command="{Binding LoadImageCommand}" InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="匯出標註 JSON" Command="{Binding ExportAnnotationsCommand}" InputGestureText="Ctrl+S"/>
                <MenuItem Header="匯入標註 JSON" Command="{Binding ImportAnnotationsCommand}" InputGestureText="Ctrl+I"/>
                <Separator/>
                <MenuItem Header="結束" Click="MenuItem_Exit"/>
            </MenuItem>
            <MenuItem Header="標註" Foreground="#CCCCCC">
                <MenuItem Header="刪除選取標註" Command="{Binding DeleteSelectedAnnotationCommand}" InputGestureText="Delete"/>
                <MenuItem Header="清除所有標註" Command="{Binding ClearAnnotationsCommand}"/>
            </MenuItem>
            <MenuItem Header="影像" Foreground="#CCCCCC">
                <MenuItem Header="重設調整參數" Command="{Binding ResetAdjustmentsCommand}"/>
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom" Background="#007ACC" Height="24">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="180"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="220" MinWidth="180"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Background="#2D2D2D">
                <StackPanel Margin="8">
                    <TextBlock Text="影像調整" Foreground="#FFFFFF" FontWeight="Bold" FontSize="13" Margin="0,0,0,8"/>

                    <Label Content="亮度" Style="{StaticResource SectionLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0" Minimum="-128" Maximum="128" Value="{Binding Brightness}"
                                Style="{StaticResource ControlSlider}" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Column="1" Text="{Binding Brightness, StringFormat=F0}"
                                   Foreground="#AAAAAA" FontSize="10" VerticalAlignment="Center" TextAlignment="Right"/>
                    </Grid>

                    <Label Content="對比度" Style="{StaticResource SectionLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0" Minimum="0.1" Maximum="4.0" Value="{Binding Contrast}"
                                Style="{StaticResource ControlSlider}"/>
                        <TextBlock Grid.Column="1" Text="{Binding Contrast, StringFormat=F2}"
                                   Foreground="#AAAAAA" FontSize="10" VerticalAlignment="Center" TextAlignment="Right"/>
                    </Grid>

                    <Label Content="Gamma" Style="{StaticResource SectionLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0" Minimum="0.1" Maximum="5.0" Value="{Binding Gamma}"
                                Style="{StaticResource ControlSlider}"/>
                        <TextBlock Grid.Column="1" Text="{Binding Gamma, StringFormat=F2}"
                                   Foreground="#AAAAAA" FontSize="10" VerticalAlignment="Center" TextAlignment="Right"/>
                    </Grid>

                    <Button Content="重設調整" Command="{Binding ResetAdjustmentsCommand}"
                            Style="{StaticResource ToolButton}" Margin="0,8,0,0"/>

                    <Separator Background="#444444" Margin="0,12"/>

                    <TextBlock Text="標註工具" Foreground="#FFFFFF" FontWeight="Bold" FontSize="13" Margin="0,0,0,8"/>

                    <RadioButton Content="矩形 (Rectangle)" Style="{StaticResource ShapeButton}"
                                 IsChecked="{Binding SelectedShape, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Rectangle}"
                                 GroupName="ShapeGroup" Checked="Rectangle_Checked"/>
                    <RadioButton Content="橢圓 (Ellipse)" Style="{StaticResource ShapeButton}"
                                 GroupName="ShapeGroup" Checked="Ellipse_Checked"/>

                    <Separator Background="#444444" Margin="0,12"/>

                    <Button Content="載入影像" Command="{Binding LoadImageCommand}"
                            Style="{StaticResource ToolButton}"/>
                    <Button Content="匯出標註 JSON" Command="{Binding ExportAnnotationsCommand}"
                            Style="{StaticResource ToolButton}"/>
                    <Button Content="匯入標註 JSON" Command="{Binding ImportAnnotationsCommand}"
                            Style="{StaticResource ToolButton}"/>

                    <Separator Background="#444444" Margin="0,12"/>

                    <TextBlock Text="操作說明" Foreground="#888888" FontSize="10" FontWeight="Bold"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#666666" FontSize="10" Margin="0,4">
                        <Run Text="• 拖曳繪製：左鍵拖曳"/>
                        <LineBreak/><Run Text="• 縮放：Ctrl + 滾輪"/>
                        <LineBreak/><Run Text="• 平移：Alt + 左鍵拖曳"/>
                        <LineBreak/><Run Text="• 選取標註：點擊標註框"/>
                        <LineBreak/><Run Text="• 刪除：選取後按 Delete"/>
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#3C3C3C"/>

            <local:ImageCanvas Grid.Column="2" x:Name="ImageCanvasControl"
                               ViewModel="{Binding}"/>

            <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" Background="#3C3C3C"/>

            <Grid Grid.Column="4" Background="#2D2D2D">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">
                    <TextBlock DockPanel.Dock="Top" Text="標註列表"
                               Foreground="#FFFFFF" FontWeight="Bold" FontSize="13"
                               Margin="8,8,8,4"/>
                    <TextBlock DockPanel.Dock="Top"
                               Text="{Binding Annotations.Count, StringFormat=共 {0} 筆標註}"
                               Foreground="#888888" FontSize="10" Margin="8,0,8,4"/>
                    <ListBox ItemsSource="{Binding Annotations}"
                             SelectedItem="{Binding SelectedAnnotation}"
                             Background="#252526"
                             BorderBrush="#444444">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="10" Height="10" Margin="0,0,6,0" VerticalAlignment="Center">
                                        <Rectangle.Fill>
                                            <SolidColorBrush Color="{Binding Color}"/>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                    <StackPanel>
                                        <TextBlock Foreground="#CCCCCC" FontSize="11">
                                            <Run Text="{Binding Shape}"/>
                                            <Run Text=" "/>
                                            <Run Text="{Binding PositionText}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Label}" Foreground="#888888" FontSize="10"
                                                   Visibility="{Binding Label, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>

                <StackPanel Grid.Row="1" Margin="8">
                    <Separator Background="#444444" Margin="0,0,0,8"/>
                    <TextBlock Text="標註屬性" Foreground="#FFFFFF" FontWeight="Bold" FontSize="12" Margin="0,0,0,6"
                               Visibility="{Binding SelectedAnnotation, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <Grid Visibility="{Binding SelectedAnnotation, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="標籤:" Foreground="#AAAAAA" FontSize="11" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Text="{Binding SelectedAnnotation.Label, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#3C3C3C" Foreground="#CCCCCC" BorderBrush="#555555"
                                 FontSize="11" Padding="3"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="顏色:" Foreground="#AAAAAA" FontSize="11" VerticalAlignment="Center" Margin="0,4,0,0"/>
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Text="{Binding SelectedAnnotation.Color, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#3C3C3C" Foreground="#CCCCCC" BorderBrush="#555555"
                                 FontSize="11" Padding="3" Margin="0,4,0,0"/>
                    </Grid>
                    <Button Content="刪除選取標註" Command="{Binding DeleteSelectedAnnotationCommand}"
                            Style="{StaticResource ToolButton}"
                            Visibility="{Binding SelectedAnnotation, Converter={StaticResource BoolToVisibilityConverter}}"
                            Margin="0,8,0,2"/>
                    <Button Content="清除所有標註" Command="{Binding ClearAnnotationsCommand}"
                            Style="{StaticResource ToolButton}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
