<Window x:Class="PluginArchitecture.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Plugin Architecture - 外掛式影像分析系統"
        Height="700" Width="1100"
        Background="#1E1E2E">

    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="4"/>
        </Style>

        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#BAC2DE"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#89B4FA"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#74C7EC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#588FA0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#F38BA8"/>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#A6E3A1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource CardStyle}" Margin="4,4,4,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="&#x1F9E9;" FontSize="24" Margin="0,0,10,0"/>
                <StackPanel>
                    <TextBlock Text="Plugin Architecture" Foreground="#CDD6F4" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="外掛式影像分析系統 | MVVM + DI + Abstract Factory + Plugin Pattern"
                               Style="{StaticResource LabelText}" Opacity="0.7"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Left Panel: Plugin List -->
        <Grid Grid.Row="1" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Plugin List -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="外掛清單" Style="{StaticResource HeaderText}"/>
                    <ListBox ItemsSource="{Binding Plugins}"
                             SelectedItem="{Binding SelectedPlugin}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,3"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                    CornerRadius="6" Padding="8">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#313244"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#2D2D44"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#x1F527;" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" Foreground="#CDD6F4" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Description}" Style="{StaticResource LabelText}"
                                                   Opacity="0.6" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Version, StringFormat='v{0}'}"
                                                   Foreground="#89B4FA" FontSize="10"/>
                                    </StackPanel>
                                    <CheckBox Grid.Column="2" IsChecked="{Binding IsEnabled}"
                                              VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Plugin Detail / Parameters -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="4,0,4,4">
                <StackPanel>
                    <TextBlock Text="外掛參數" Style="{StaticResource HeaderText}"/>
                    <ItemsControl ItemsSource="{Binding SelectedPlugin.Plugin.Parameters}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding DisplayName}"
                                               Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#313244" Foreground="#CDD6F4"
                                             BorderBrush="#45475A" BorderThickness="1"
                                             Padding="4,2" FontSize="11"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="請先選擇外掛以設定參數"
                               Style="{StaticResource LabelText}" Opacity="0.5"
                               HorizontalAlignment="Center" Margin="0,8"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Right Panel: Image Display -->
        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardStyle}">
            <DockPanel>
                <!-- Action Buttons -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                    <Button Content="套用選取外掛" Style="{StaticResource ActionButton}"
                            Command="{Binding ApplyPluginCommand}"/>
                    <Button Content="套用所有啟用" Style="{StaticResource SuccessButton}"
                            Command="{Binding ApplyAllEnabledCommand}"/>
                    <Button Content="重置影像" Style="{StaticResource DangerButton}"
                            Command="{Binding ResetImageCommand}"/>
                    <Button Content="產生新範例" Style="{StaticResource ActionButton}"
                            Command="{Binding GenerateNewSampleCommand}"/>
                </StackPanel>

                <!-- Image Display -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#181825" CornerRadius="6" Margin="0,0,4,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="原始影像"
                                       Style="{StaticResource LabelText}"
                                       HorizontalAlignment="Center" Margin="0,6,0,4"/>
                            <Image Source="{Binding OriginalImage}"
                                   Stretch="Uniform" Margin="4"/>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#181825" CornerRadius="6" Margin="4,0,0,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="處理後影像"
                                       Style="{StaticResource LabelText}"
                                       HorizontalAlignment="Center" Margin="0,6,0,4"/>
                            <Image Source="{Binding ProcessedImage}"
                                   Stretch="Uniform" Margin="4"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </DockPanel>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource CardStyle}" Margin="4,8,4,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#x2139;" Foreground="#89B4FA" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource LabelText}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
