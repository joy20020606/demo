<UserControl x:Class="InstrumentDashboard.Controls.GaugeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="160" Height="160">
    <Grid>
        <Canvas x:Name="GaugeCanvas" Width="160" Height="160" />
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,30,0,0">
            <TextBlock x:Name="ValueText" Text="0.00" FontSize="22" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center"/>
            <TextBlock x:Name="UnitText" Text="" FontSize="11"
                       Foreground="#AAAAAA" HorizontalAlignment="Center"/>
            <TextBlock x:Name="LabelText" Text="" FontSize="11"
                       Foreground="#CCCCCC" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
