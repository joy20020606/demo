<Window x:Class="InstrumentDashboard.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:InstrumentDashboard.Views"
        Title="Instrument Control Dashboard" Height="760" Width="1200"
        Background="#121218" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1A1A2E" BorderBrush="#2D2D4E" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Instrument Control Dashboard" FontSize="18" FontWeight="Bold"
                               Foreground="White"/>
                    <Border Background="{Binding StateColor}" CornerRadius="10"
                            Padding="10,3" Margin="16,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding StateDisplayName}" Foreground="White"
                                   FontSize="12" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Start" Command="{Binding StartCommand}"
                            Style="{StaticResource ActionButton}"
                            Background="#2E7D32" IsEnabled="{Binding CanStart}"
                            Margin="0,0,8,0"/>
                    <Button Content="Stop" Command="{Binding StopCommand}"
                            Style="{StaticResource ActionButton}"
                            Background="#B71C1C" IsEnabled="{Binding CanStop}"
                            Margin="0,0,8,0"/>
                    <Button Content="Reset" Command="{Binding ResetCommand}"
                            Style="{StaticResource ActionButton}"
                            Background="#4527A0" IsEnabled="{Binding CanReset}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1E1E2E" BorderBrush="#2D2D4E" BorderThickness="0,0,1,0">
                <views:ParameterPanel DataContext="{Binding ParameterPanel}"/>
            </Border>

            <views:StatusDashboard Grid.Column="1" DataContext="{Binding StatusDashboard}"/>
        </Grid>

        <Border Grid.Row="2" Background="#1A1A2E" BorderBrush="#2D2D4E" BorderThickness="0,1,0,0">
            <views:LogPanel DataContext="{Binding Log}"/>
        </Border>
    </Grid>
</Window>
