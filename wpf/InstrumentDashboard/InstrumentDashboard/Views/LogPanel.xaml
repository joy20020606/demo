<UserControl x:Class="InstrumentDashboard.Views.LogPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:InstrumentDashboard.Converters">
    <UserControl.Resources>
        <converters:LogLevelToColorConverter x:Key="LevelToColor"/>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3D5A80"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#1A1A2E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Operation Log" FontSize="14" FontWeight="Bold"
                   Foreground="White" Margin="12,8"/>

        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Entries}"
                 Background="#0F0F1A"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 VirtualizingPanel.ScrollUnit="Pixel">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Display}"
                               Foreground="{Binding Level, Converter={StaticResource LevelToColor}}"
                               FontFamily="Consolas"
                               FontSize="11"
                               Margin="4,1"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="8,4">
            <Button Content="Export" Command="{Binding ExportCommand}" Margin="0,0,8,0"/>
            <Button Content="Clear" Command="{Binding ClearCommand}"
                    Background="#5C3C3C"/>
        </StackPanel>
    </Grid>
</UserControl>
