<UserControl x:Class="InstrumentDashboard.Views.StatusDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:InstrumentDashboard.Controls">
    <StackPanel Margin="12" Background="#1E1E2E">
        <TextBlock Text="Live Status" FontSize="14" FontWeight="Bold"
                   Foreground="White" Margin="0,0,0,12"/>

        <WrapPanel HorizontalAlignment="Center">
            <controls:GaugeControl Value="{Binding Temperature}"
                                   Minimum="0" Maximum="100"
                                   Label="Temperature" Unit="°C"
                                   GaugeColor="#FF5733"
                                   Margin="8"/>

            <controls:GaugeControl Value="{Binding Pressure}"
                                   Minimum="0" Maximum="200"
                                   Label="Pressure" Unit="kPa"
                                   GaugeColor="#33A1FF"
                                   Margin="8"/>

            <controls:GaugeControl Value="{Binding Vacuum}"
                                   Minimum="0" Maximum="0.001"
                                   Label="Vacuum" Unit="Pa"
                                   Format="E2"
                                   GaugeColor="#A833FF"
                                   Margin="8"/>

            <controls:GaugeControl Value="{Binding Voltage}"
                                   Minimum="0" Maximum="20"
                                   Label="Voltage" Unit="V"
                                   GaugeColor="#FFD700"
                                   Margin="8"/>

            <controls:GaugeControl Value="{Binding Current}"
                                   Minimum="0" Maximum="1"
                                   Label="Current" Unit="A"
                                   GaugeColor="#33FF99"
                                   Margin="8"/>
        </WrapPanel>

        <Separator Background="#444444" Margin="0,12"/>

        <TextBlock Text="Progress" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,4"/>
        <Grid>
            <ProgressBar Value="{Binding Progress}" Minimum="0" Maximum="100"
                         Height="20" Background="#2D2D2D" Foreground="#2196F3"
                         BorderBrush="#555555"/>
            <TextBlock Text="{Binding Progress, StringFormat={}{0:F1}%}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="White" FontSize="11"/>
        </Grid>
    </StackPanel>
</UserControl>
