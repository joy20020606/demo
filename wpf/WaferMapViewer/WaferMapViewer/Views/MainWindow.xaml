<Window x:Class="WaferMapViewer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:WaferMapViewer.Views"
        Title="Wafer Map Viewer" Height="720" Width="1200"
        Background="#12121E" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="#0D0D1A">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Wafer Map Viewer" FontSize="18" FontWeight="Bold"
                           Foreground="#9090D0" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Generate New Wafer"
                        Command="{Binding GenerateWaferCommand}"
                        Style="{StaticResource ModernButton}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <views:WaferMapPanel Grid.Row="1" Grid.Column="0"
                             DataContext="{Binding WaferMapVM}"
                             x:Name="WaferPanel"/>

        <views:DieDetailPanel Grid.Row="1" Grid.Column="1"
                              DataContext="{Binding DieDetailVM}"/>

        <views:StatisticsPanel Grid.Row="1" Grid.Column="2"
                               DataContext="{Binding StatisticsVM}"/>
    </Grid>
</Window>
