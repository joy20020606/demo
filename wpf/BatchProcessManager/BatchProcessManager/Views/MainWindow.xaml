<Window x:Class="BatchProcessManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:BatchProcessManager.Views"
        Title="BatchProcessManager - 批次處理管理器"
        Width="1200" Height="750"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <DockPanel Margin="16,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" DockPanel.Dock="Left">
                    <TextBlock Text="⚙" FontSize="22" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="BatchProcessManager" FontSize="16" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text="批次處理管理器" FontSize="12" Foreground="#BBDEFB"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="▶ 開始執行批次"
                            Command="{Binding StartBatchCommand}"
                            Background="White" Foreground="{StaticResource PrimaryBrush}"
                            BorderThickness="0" Padding="16,7" FontSize="13" FontWeight="SemiBold"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E3F2FD"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#78909C"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}"
                    BorderThickness="0" Background="{StaticResource BackgroundBrush}">

            <TabItem Header="任務佇列">
                <views:TaskQueuePanel DataContext="{Binding TaskQueue}"/>
            </TabItem>

            <TabItem Header="執行監控">
                <views:ExecutionPanel DataContext="{Binding Execution}"/>
            </TabItem>

            <TabItem Header="執行報表">
                <views:ReportPanel DataContext="{Binding Report}"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
