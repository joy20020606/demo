<UserControl x:Class="BatchProcessManager.Views.ExecutionPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:BatchProcessManager.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisible"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisible"/>
        <conv:BoolToSuccessColorConverter x:Key="BoolToSuccessColor"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="12,12,6,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="執行進度" Style="{StaticResource SectionTitleStyle}" DockPanel.Dock="Left"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,10,0"/>
                            <Button Content="取消" Command="{Binding CancelCommand}"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisible}}"/>
                        </StackPanel>
                    </DockPanel>

                    <ProgressBar Grid.Row="1" Value="{Binding OverallProgress, Mode=OneWay}"
                                 Maximum="100" Height="20" Margin="0,0,0,8"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="整體進度" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"
                                       Foreground="{StaticResource PrimaryBrush}">
                                <Run Text="{Binding OverallProgress, StringFormat='{}{0:F0}', Mode=OneWay}"/>
                                <Run Text="%"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="已耗時" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding ElapsedText}" FontSize="20" FontWeight="Bold"
                                       HorizontalAlignment="Center" FontFamily="Consolas"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="預估完成" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding EstimatedEndText}" FontSize="20" FontWeight="Bold"
                                       HorizontalAlignment="Center" FontFamily="Consolas"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="執行設定" Style="{StaticResource SectionTitleStyle}"/>

                    <WrapPanel Grid.Row="1">
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                            <TextBlock Text="最大並行數：" VerticalAlignment="Center" FontSize="13"/>
                            <Slider Minimum="1" Maximum="10" Value="{Binding Config.MaxConcurrency}"
                                    Width="120" VerticalAlignment="Center" IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolToVisible}}"/>
                            <TextBlock Text="{Binding Config.MaxConcurrency}" VerticalAlignment="Center"
                                       Margin="6,0,0,0" FontWeight="Bold" MinWidth="20"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                            <TextBlock Text="最大重試數：" VerticalAlignment="Center" FontSize="13"/>
                            <Slider Minimum="0" Maximum="5" Value="{Binding Config.MaxRetries}"
                                    Width="100" VerticalAlignment="Center" IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolToVisible}}"/>
                            <TextBlock Text="{Binding Config.MaxRetries}" VerticalAlignment="Center"
                                       Margin="6,0,0,0" FontWeight="Bold" MinWidth="20"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                            <TextBlock Text="重試延遲(s)：" VerticalAlignment="Center" FontSize="13"/>
                            <Slider Minimum="1" Maximum="10" Value="{Binding Config.RetryDelaySeconds}"
                                    Width="100" VerticalAlignment="Center" IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolToVisible}}"/>
                            <TextBlock Text="{Binding Config.RetryDelaySeconds}" VerticalAlignment="Center"
                                       Margin="6,0,0,0" FontWeight="Bold" MinWidth="20"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="失敗即停：" VerticalAlignment="Center" FontSize="13"/>
                            <CheckBox IsChecked="{Binding Config.StopOnFirstFailure}"
                                      VerticalAlignment="Center"
                                      IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolToVisible}}"/>
                        </StackPanel>
                    </WrapPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="執行結果" Style="{StaticResource SectionTitleStyle}"/>
                    <ListView Grid.Row="1" ItemsSource="{Binding Results}" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="任務" Width="150" DisplayMemberBinding="{Binding TaskName}"/>
                                <GridViewColumn Header="狀態" Width="60">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StatusText}"
                                                       Foreground="{Binding IsSuccess, Converter={StaticResource BoolToSuccessColor}}"
                                                       FontWeight="SemiBold"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="耗時" Width="60" DisplayMemberBinding="{Binding DurationText}"/>
                                <GridViewColumn Header="重試" Width="40" DisplayMemberBinding="{Binding RetryCount}"/>
                                <GridViewColumn Header="錯誤訊息" Width="140" DisplayMemberBinding="{Binding ErrorMessage}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="6,12,12,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="執行記錄" Style="{StaticResource SectionTitleStyle}"/>
                <ListBox Grid.Row="1" ItemsSource="{Binding ExecutionLog}"
                         BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                         FontFamily="Consolas" FontSize="11"
                         Background="#FAFAFA">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
