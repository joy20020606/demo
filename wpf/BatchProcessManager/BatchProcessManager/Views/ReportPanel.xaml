<UserControl x:Class="BatchProcessManager.Views.ReportPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:BatchProcessManager.Converters">

    <UserControl.Resources>
        <conv:BoolToSuccessColorConverter x:Key="BoolToSuccessColor"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="12,12,12,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="執行報表" Style="{StaticResource SectionTitleStyle}" DockPanel.Dock="Left"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="匯出 JSON" Command="{Binding ExportReportCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                    </StackPanel>
                </DockPanel>

                <WrapPanel Grid.Row="1">
                    <Border Margin="0,0,12,0" Padding="16,10" Background="#E8F5E9" CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="總任務數" FontSize="11" Foreground="#388E3C" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalCount}" FontSize="28" FontWeight="Bold"
                                       Foreground="#2E7D32" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Margin="0,0,12,0" Padding="16,10" Background="#E3F2FD" CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="成功" FontSize="11" Foreground="#1565C0" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding SuccessCount}" FontSize="28" FontWeight="Bold"
                                       Foreground="#0D47A1" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Margin="0,0,12,0" Padding="16,10" Background="#FFEBEE" CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="失敗" FontSize="11" Foreground="#C62828" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding FailedCount}" FontSize="28" FontWeight="Bold"
                                       Foreground="#B71C1C" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Margin="0,0,12,0" Padding="16,10" Background="#FFF8E1" CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="成功率" FontSize="11" Foreground="#E65100" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding SuccessRate}" FontSize="28" FontWeight="Bold"
                                       Foreground="#BF360C" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Margin="0,0,0,0" Padding="16,10" Background="#F3E5F5" CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="總耗時" FontSize="11" Foreground="#6A1B9A" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalDuration}" FontSize="28" FontWeight="Bold"
                                       Foreground="#4A148C" HorizontalAlignment="Center" FontFamily="Consolas"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="12,0,12,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="詳細結果" Style="{StaticResource SectionTitleStyle}"/>

                <ListView Grid.Row="1" ItemsSource="{Binding Results}"
                          BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="任務 ID" Width="80" DisplayMemberBinding="{Binding TaskId}"/>
                            <GridViewColumn Header="任務名稱" Width="160" DisplayMemberBinding="{Binding TaskName}"/>
                            <GridViewColumn Header="狀態" Width="70">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Padding="6,2" CornerRadius="3"
                                                Background="{Binding IsSuccess, Converter={StaticResource BoolToSuccessColor}}">
                                            <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="耗時" Width="70" DisplayMemberBinding="{Binding DurationText}"/>
                            <GridViewColumn Header="重試次數" Width="70" DisplayMemberBinding="{Binding RetryCount}"/>
                            <GridViewColumn Header="完成時間" Width="140">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding CompletedAt, StringFormat='yyyy-MM-dd HH:mm:ss'}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="錯誤訊息" Width="160" DisplayMemberBinding="{Binding ErrorMessage}"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <TextBlock Grid.Row="2" Margin="0,8,0,0"
                           Text="{Binding ExportStatus}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" FontStyle="Italic"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
